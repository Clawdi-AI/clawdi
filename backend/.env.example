DATABASE_URL=postgresql+asyncpg://clawdi:clawdi_dev@localhost:5433/clawdi

CLERK_PEM_PUBLIC_KEY=

# Generate each with: python3 -c "import os; print(os.urandom(32).hex())"
# The two keys must be DIFFERENT — one encrypts vault data at rest,
# the other signs MCP proxy JWTs.
VAULT_ENCRYPTION_KEY=
ENCRYPTION_KEY=

# `local` = fastembed ONNX (the only implementation right now). s3 / r2
# will plug in here without touching routes (see services/file_store.py).
FILE_STORE_TYPE=local
FILE_STORE_LOCAL_PATH=./data/files

DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]

# Admin API key — gates `/api/admin/*` server-to-server endpoints used by
# upstream-SaaS batch tooling (deploy mint, account-deletion revoke, live-sync
# migration of legacy deployments). Default empty = endpoints return 503
# (OSS self-hosters who don't run an upstream SaaS shouldn't expose this
# surface).
#
# When wiring up a SaaS frontend, set this to a strong secret
# (`openssl rand -hex 32`) and configure the matching `CLAWDI_CLOUD_ADMIN_API_KEY`
# on the SaaS backend side. Constant-time HMAC comparison.
ADMIN_API_KEY=

# Externally reachable URLs the backend embeds in payloads it hands out.
# PUBLIC_API_URL: this backend's own URL (used for MCP client config etc.).
# WEB_ORIGIN:     the dashboard URL — the CLI device-flow `verification_uri`
#                 is built from this, so the user opens the right host in
#                 their browser. In prod, set to e.g. https://cloud.clawdi.ai.
PUBLIC_API_URL=http://localhost:8000
WEB_ORIGIN=http://localhost:3000

# From composio.dev dashboard. Leave blank to disable connectors.
COMPOSIO_API_KEY=

# --- Memory embedder (used by the Builtin memory provider) ---
# local = fastembed ONNX, ~1GB download on first use, no API key. Default.
# api   = OpenAI-compatible API. Set MEMORY_EMBEDDING_API_KEY and
#         optionally MEMORY_EMBEDDING_BASE_URL + MEMORY_EMBEDDING_MODEL.
MEMORY_EMBEDDING_MODE=local
MEMORY_EMBEDDING_API_KEY=

# e.g. https://openrouter.ai/api/v1
MEMORY_EMBEDDING_BASE_URL=

MEMORY_EMBEDDING_MODEL=text-embedding-3-small
