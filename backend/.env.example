DATABASE_URL=postgresql+asyncpg://clawdi:clawdi_dev@localhost:5433/clawdi_cloud
CLERK_PEM_PUBLIC_KEY=

# Generate with: python3 -c "import os; print(os.urandom(32).hex())"
VAULT_ENCRYPTION_KEY=

FILE_STORE_TYPE=local
FILE_STORE_LOCAL_PATH=./data/files
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]

# For JWT signing (MCP proxy tokens). Same format as VAULT_ENCRYPTION_KEY.
ENCRYPTION_KEY=

# From composio.dev dashboard
COMPOSIO_API_KEY=

# --- Memory embedder (used by the Builtin memory provider) ---
# local = fastembed ONNX, ~1GB download, no API key. Default.
# api   = OpenAI-compatible API. Set MEMORY_EMBEDDING_API_KEY and
#         optionally MEMORY_EMBEDDING_BASE_URL + MEMORY_EMBEDDING_MODEL.
MEMORY_EMBEDDING_MODE=local
MEMORY_EMBEDDING_API_KEY=
MEMORY_EMBEDDING_BASE_URL=  # e.g. https://openrouter.ai/api/v1
MEMORY_EMBEDDING_MODEL=text-embedding-3-small
