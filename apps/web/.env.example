# Clerk (required except when using local `NEXT_PUBLIC_DEV_AUTH_BYPASS=true`).
# Dev instance keys: https://dashboard.clerk.com → pick the application that
# owns clawdi.ai → API keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Backend base URL (required in prod; dev falls back to http://localhost:8000
# if unset). Production Vercel value: https://cloud-api.clawdi.ai
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional product-owned preset avatar base. When set, the dashboard shows
# fixed preset ids using `${NEXT_PUBLIC_AGENT_AVATAR_PRESET_BASE_URL}/{id}.webp`.
# Do not point this at user-provided URLs.
NEXT_PUBLIC_AGENT_AVATAR_PRESET_BASE_URL=

# Local-only browser testing bypass. Also set DEV_AUTH_BYPASS=true on the
# backend; the frontend will skip Clerk middleware in `next dev` and send
# `Authorization: Bearer dev-bypass` to NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_DEV_AUTH_BYPASS=
NEXT_PUBLIC_DEV_AUTH_TOKEN=dev-bypass

# Hosted-only — clawdi.ai, where the hosted-agents listing card
# cross-origins to `/deployments` (clawdi.ai's deployments router
# mounts at root, no `/api` prefix — different from cloud-api's
# convention). Connectors are NOT hosted: even cloud.clawdi.ai
# routes connector traffic through cloud-api now.
# Production Vercel value: https://api.clawdi.ai
# Dev fallback: http://localhost:50021 (clawdi.ai).
NEXT_PUBLIC_DEPLOY_API_URL=http://localhost:50021

# Build-time flag — `true` enables the hosted-only UI surfaces:
# the deployed-agents tile listing on the dashboard and the Deploy
# CTA in the sidebar. OSS / self-host instances should leave this
# unset.
NEXT_PUBLIC_CLAWDI_HOSTED=

# Hosted-only analytics (optional). When set alongside
# `NEXT_PUBLIC_CLAWDI_HOSTED=true`, PostHog initializes with a
# first-party proxy at `/_cdi/px`.
NEXT_PUBLIC_POSTHOG_TOKEN=
