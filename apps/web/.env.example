# Clerk (required — app won't start without these).
# Dev instance keys: https://dashboard.clerk.com → pick the application that
# owns clawdi.ai → API keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Backend base URL (required in prod; dev falls back to http://localhost:8000
# if unset). Production Vercel value: https://cloud-api.clawdi.ai
NEXT_PUBLIC_API_URL=http://localhost:8000

# Hosted-only — clawdi-monorepo's deploy backend, where the
# Hosted-agents listing card cross-origins to `/deployments`
# (note: monorepo's deployments router mounts at root, no `/api`
# prefix — different from cloud-api's convention).
# Production Vercel value: https://api.clawdi.ai
# Dev fallback: http://localhost:50021 (clawdi-monorepo backend).
NEXT_PUBLIC_DEPLOY_API_URL=http://localhost:50021

# Build-time flag — `true` enables the hosted-only UI surfaces.
# OSS / self-host instances should leave this unset.
NEXT_PUBLIC_CLAWDI_HOSTED=

# Optional — comma-separated email-domain allowlist. Users with emails
# outside these domains are redirected to /access-denied after sign-in.
# Unset or empty = no restriction (anyone signed in via Clerk gets in).
ALLOWED_EMAIL_DOMAINS=
