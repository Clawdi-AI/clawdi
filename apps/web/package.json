		"@types/react-dom": "catalog:",
		"@vitejs/plugin-react": "^6.0.3",
		"tailwindcss": "catalog:",
		"typescript": "catalog:",
		"vite": "^8.1.0"
	},
	"ignoreScripts": [
		"sharp",
		"unrs-resolver"
	],
	"trustedDependencies": [
		"sharp",
		"unrs-resolver"
	]
