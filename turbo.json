{
	"$schema": "https://turbo.build/schema.json",
	"globalDependencies": [
		"package.json",
		"bun.lock",
		"turbo.json",
		"tsconfig.base.json",
		"biome.json"
	],
	"tasks": {
		"dev": {
			"cache": false,
			"persistent": true
		},
		"build": {
			"dependsOn": ["^build"],
			"env": ["NODE_ENV"],
			"outputs": ["dist/**"]
		},
		"typecheck": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/tsconfig.base.json"],
			"outputs": []
		},
		"lint": {
			"inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/biome.json"],
			"outputs": []
		},
		"test": {
			"dependsOn": ["typecheck"],
			"outputs": []
		}
	}
}
