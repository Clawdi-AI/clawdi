# Coolify Application runtime environment for the Clawdi backend.
#
# Store real values once as Coolify environment shared variables, then wire
# each Application env row as KEY={{environment.KEY}}. Values are runtime-only;
# do not expose these at build time.

ADMIN_API_KEY=
CLERK_PEM_PUBLIC_KEY=replace-with-clerk-pem
COMPOSIO_API_KEY=
CORS_ORIGINS=["https://app.example.com"]
DATABASE_URL=postgresql+asyncpg://<user>:<password>@host.docker.internal:5432/<database>
DEBUG=false
ENCRYPTION_KEY=replace-with-encryption-key
ENVIRONMENT=production
FILE_STORE_LOCAL_PATH=/data/files
FILE_STORE_TYPE=local
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o-mini
MEMORY_EMBEDDING_MODE=local
MEMORY_EMBEDDING_API_KEY=
MEMORY_EMBEDDING_BASE_URL=
MEMORY_EMBEDDING_MODEL=text-embedding-3-small
PUBLIC_API_URL=https://api.example.com
TRUST_FORWARDED_FOR=true
VAULT_ENCRYPTION_KEY=replace-with-vault-key
WEB_ORIGIN=https://app.example.com
