# Copy to .env and fill values before running docker compose.

POSTGRES_DB=clawdi
POSTGRES_USER=clawdi
POSTGRES_PASSWORD=change-me

CLAWDI_BACKEND_IMAGE=ghcr.io/clawdi-ai/clawdi-backend
CLAWDI_BACKEND_IMAGE_TAG=local
CLAWDI_WEB_IMAGE=ghcr.io/clawdi-ai/clawdi-web
CLAWDI_WEB_IMAGE_TAG=local

PUBLIC_API_URL=http://localhost:8000
WEB_ORIGIN=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000"]
TRUST_FORWARDED_FOR=false

API_HOST=127.0.0.1
API_PORT=8000
WEB_HOST=127.0.0.1
WEB_PORT=3000
NEXT_PUBLIC_DEPLOY_API_URL=http://localhost:50021

# Clerk dashboard authentication.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_PEM_PUBLIC_KEY=

# Generate each with:
# python3 -c "import os; print(os.urandom(32).hex())"
VAULT_ENCRYPTION_KEY=
ENCRYPTION_KEY=

ADMIN_API_KEY=
COMPOSIO_API_KEY=

MEMORY_EMBEDDING_MODE=local
MEMORY_EMBEDDING_API_KEY=
MEMORY_EMBEDDING_BASE_URL=
MEMORY_EMBEDDING_MODEL=text-embedding-3-small

LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
