{
	"name": "clawdi",
	"version": "0.12.10-beta.49",
	"description": "iCloud for AI Agents — cross-agent sessions, skills, memory, and vault.",
	"license": "MIT",
	"type": "module",
	"sideEffects": false,
	"bin": {
		"clawdi": "bin/clawdi.mjs"
	},
	"files": [
		"bin",
		"dist",
		"egress-addon",
		"LICENSE",
		"README.md"
	],
	"engines": {
		"node": ">=22.5"
	},
	"publishConfig": {
		"access": "public",
		"tag": "agent-v2-candidate"
	},
	"scripts": {
		"dev": "bun run src/index.ts",
		"build": "rm -rf dist && bun build src/index.ts --outdir dist --target node --minify --define 'process.env.CLAWDI_DEFAULT_API_URL=\"https://cloud-api.clawdi.ai\"' && cp -r skills dist/skills",
		"build:binary": "bun run scripts/build-binary.mjs",
		"package:binary-release": "bun run scripts/package-binary-release.mjs",
		"build:dev": "rm -rf dist && bun build src/index.ts --outdir dist --target node && cp -r skills dist/skills",
		"check:publish-manifest": "node scripts/check-publish-manifest.mjs",
		"typecheck": "tsc --noEmit",
		"test": "bun test --isolate --max-concurrency=1",
		"test:e2e": "bun test --isolate --max-concurrency=1 tests/e2e",
		"test:watch": "bun test --watch",
		"prepublishOnly": "bun run build"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Clawdi-AI/clawdi.git",
		"directory": "packages/cli"
	},
	"bugs": {
		"url": "https://github.com/Clawdi-AI/clawdi/issues"
	},
	"homepage": "https://github.com/Clawdi-AI/clawdi#readme",
	"keywords": [
		"cli",
		"claude-code",
		"codex",
		"openclaw",
		"hermes",
		"ai-agents",
		"skills",
		"memory",
		"vault",
		"mcp"
	],
	"devDependencies": {
		"@clack/prompts": "^1.7.0",
		"@clawdi/shared": "workspace:*",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@types/bun": "^1.3.12",
		"@types/node": "^22.20.0",
		"chalk": "^5.4.0",
		"commander": "^15.0.0",
		"openapi-fetch": "^0.17.0",
		"tar": "^7.5.19",
		"typescript": "catalog:",
		"yaml": "^2.9.0",
		"zod": "catalog:"
	}
}
