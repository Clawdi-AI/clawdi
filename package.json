{
	"name": "clawdi",
	"private": true,
	"license": "MIT",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"catalog": {
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"typescript": "^7.0.2",
		"zod": "^4.4.3",
		"tailwindcss": "^4.3.2",
		"@tailwindcss/postcss": "^4.3.2",
		"@tailwindcss/vite": "^4.3.2",
		"@tanstack/react-query": "^5.101.2",
		"lucide-react": "^1.23.0",
		"tailwind-merge": "^3.6.0",
		"clsx": "^2.1.1"
	},
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"typecheck": "turbo typecheck",
		"test": "scripts/test.sh",
		"test:local": "turbo test",
		"check": "biome ci .",
		"check:fix": "biome check --write .",
		"generate-api": "scripts/openapi-typescript.sh http://localhost:8000/openapi.json -o packages/shared/src/api/api.generated.ts",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"format": "biome format --write .",
		"prepare": "node scripts/install-git-hooks.mjs"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"lefthook": "^2.1.10",
		"turbo": "^2.10.4",
		"typescript": "catalog:"
	},
	"engines": {
		"node": "24.x",
		"bun": ">=1.3.0"
	},
	"packageManager": "bun@1.3.14",
	"overrides": {
		"dompurify": "3.4.11",
		"fast-uri": "4.1.0",
		"hono": "4.12.27",
		"ip-address": "10.2.0",
		"js-cookie": "3.0.8",
		"js-yaml": "4.3.0",
		"protobufjs": "7.6.5",
		"qs": "6.15.3",
		"tar": "7.5.19"
	}
}
