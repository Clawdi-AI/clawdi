!/packages/cli/tests/fixtures/**/dist
!/packages/cli/tests/fixtures/**/dist/**
!/packages/cli/tests/fixtures/**/__pycache__
!/packages/cli/tests/fixtures/**/__pycache__/**

# PDM (local interpreter path — machine-specific)
.pdm-python

